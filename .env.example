# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<dbUser>:<dbPassword>@cluster0.xxxxx.mongodb.net/coinbase_clone?retryWrites=true&w=majority&appName=Cluster0

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES=1d

# Frontend URL (Netlify or local frontend URL)
FRONTEND_ORIGIN=https://your-frontend-site.netlify.app